{
  "openapi": "3.1.1",
  "info": {
    "title": "Services.Libraries | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/libraries": {
      "get": {
        "tags": [
          "Libraries"
        ],
        "summary": "List of all configured library extensions",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Library"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/libraries/komga": {
      "put": {
        "tags": [
          "Libraries"
        ],
        "summary": "Add komga library extension",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddKomgaLibraryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/libraries/{libraryId}": {
      "delete": {
        "tags": [
          "Libraries"
        ],
        "summary": "Remove a library extension",
        "parameters": [
          {
            "name": "libraryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddKomgaLibraryRequest": {
        "required": [
          "name",
          "baseUrl",
          "apiKey"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "baseUrl": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          },
          "libraryRootPath": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "Library": {
        "required": [
          "libraryServiceType",
          "id",
          "baseUrl"
        ],
        "type": "object",
        "properties": {
          "libraryServiceType": {
            "$ref": "#/components/schemas/LibraryServiceType"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "baseUrl": {
            "type": "string"
          }
        }
      },
      "LibraryServiceType": {
        "enum": [
          "Komga"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "Libraries"
    }
  ]
}