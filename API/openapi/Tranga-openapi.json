{
  "openapi": "3.1.1",
  "info": {
    "title": "API | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/manga/search": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Searches for a Manga",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchQuery"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The Search-result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaSearchResult"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error while searching for Manga"
          }
        }
      }
    },
    "/manga/{mangaId}/watch": {
      "post": {
        "tags": [
          "Download"
        ],
        "summary": "Mark a Manga to be (un-)watched for downloads",
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "description": "Id of the Manga",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "download",
            "in": "query",
            "description": "true to watch the Manga",
            "required": true,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Manga is marked"
          },
          "404": {
            "description": "Manga could not be found"
          }
        }
      }
    },
    "/manga/{mangaId}/match": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Matches the Manga on all DownloadExtensions",
        "description": "PostSearchMangaEndpoint",
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "description": "The ID of the Manga to search for",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A List of matched Manga",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaSearchResult"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Manga could not be found"
          }
        }
      }
    },
    "/chapter/{chapterId}/download": {
      "post": {
        "tags": [
          "Download"
        ],
        "summary": "Downloads a chapter",
        "parameters": [
          {
            "name": "chapterId",
            "in": "path",
            "description": "Id of the Chapter",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chapter will be downloaded"
          },
          "404": {
            "description": "Chapter could not be found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContentRating": {
        "enum": [
          "Safe",
          "Suggestive",
          "Erotica",
          "Pornographic",
          null
        ]
      },
      "MangaSearchResult": {
        "required": [
          "title",
          "description",
          "coverBase64",
          "url"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the Manga"
          },
          "description": {
            "type": "string",
            "description": "The description of the Manga"
          },
          "coverBase64": {
            "type": "string",
            "description": "The cover image as Base64 string"
          },
          "url": {
            "type": "string",
            "description": "Url of the Manga"
          }
        },
        "description": "The result of PostSearchMangaEndpoint"
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "null",
              "string"
            ],
            "description": "The title of the Manga."
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "contentRating": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ContentRating"
              }
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The release-year of the Manga",
            "format": "int32"
          },
          "author": {
            "type": [
              "null",
              "string"
            ],
            "description": "An author of the Manga"
          },
          "artist": {
            "type": [
              "null",
              "string"
            ],
            "description": "An artist of the Manga"
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The ISO language-code of a translation"
          },
          "mangaUpdatesSeriesId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The MangaUpdates.com series id",
            "format": "int64"
          }
        },
        "description": "The query to use when searching for a Manga"
      }
    }
  },
  "tags": [
    {
      "name": "Search"
    },
    {
      "name": "Download"
    }
  ]
}