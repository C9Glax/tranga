{
  "openapi": "3.1.1",
  "info": {
    "title": "API | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/manga/search": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Searches for a Manga",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchQuery"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The Search-result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaSearchResultDTO"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error while searching for Manga"
          }
        }
      }
    },
    "/manga/{mangaId}/watch": {
      "post": {
        "tags": [
          "Download"
        ],
        "summary": "Mark a Manga to be (un-)watched for downloads",
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "description": "Id of the Manga",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "download",
            "in": "query",
            "description": "true to watch the Manga",
            "required": true,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Manga is marked"
          },
          "404": {
            "description": "Manga could not be found"
          }
        }
      }
    },
    "/manga/{mangaId}/match": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Matches the Manga on all DownloadExtensions",
        "description": "PostSearchMangaEndpoint",
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "description": "The ID of the Manga to match",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A List of matched Manga",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaSearchResultDTO"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Manga could not be found"
          }
        }
      }
    },
    "/chapter/{chapterId}/download": {
      "post": {
        "tags": [
          "Download"
        ],
        "summary": "Downloads a chapter",
        "parameters": [
          {
            "name": "chapterId",
            "in": "path",
            "description": "Id of the Chapter",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chapter will be downloaded"
          },
          "404": {
            "description": "Chapter could not be found"
          }
        }
      }
    },
    "/metadataExtensions": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "Get all Metadata-Extensions",
        "responses": {
          "200": {
            "description": "A list of all Metadata-Extension",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MetadataExtensionDTO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/downloadExtensions": {
      "get": {
        "tags": [
          "Download"
        ],
        "summary": "Get all Download-Extensions",
        "responses": {
          "200": {
            "description": "A list of all Download-Extension",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DownloadExtensionDTO"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContentRating": {
        "enum": [
          "Safe",
          "Suggestive",
          "Erotica",
          "Pornographic",
          null
        ]
      },
      "DownloadExtensionDTO": {
        "required": [
          "extensionIdentifier",
          "name",
          "url"
        ],
        "type": "object",
        "properties": {
          "extensionIdentifier": {
            "type": "string",
            "description": "The unique Identifier of this Extension",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "The name of the Extension"
          },
          "url": {
            "type": "string",
            "description": "The Url of the Extension"
          }
        },
        "description": "A Download-Extension"
      },
      "MangaSearchResultDTO": {
        "required": [
          "title",
          "description",
          "coverBase64",
          "url"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the Manga"
          },
          "description": {
            "type": "string",
            "description": "The description of the Manga"
          },
          "coverBase64": {
            "type": "string",
            "description": "The cover image as Base64 string"
          },
          "url": {
            "type": "string",
            "description": "Url of the Manga"
          }
        },
        "description": "A Search Result"
      },
      "MetadataExtensionDTO": {
        "required": [
          "extensionIdentifier",
          "name",
          "url"
        ],
        "type": "object",
        "properties": {
          "extensionIdentifier": {
            "type": "string",
            "description": "The unique Identifier of this Extension",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "The name of the Extension"
          },
          "url": {
            "type": "string",
            "description": "The Url of the Extension"
          }
        },
        "description": "A Metadata-Extension"
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "null",
              "string"
            ],
            "description": "The title of the Manga."
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "contentRating": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ContentRating"
              }
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The release-year of the Manga",
            "format": "int32"
          },
          "author": {
            "type": [
              "null",
              "string"
            ],
            "description": "An author of the Manga"
          },
          "artist": {
            "type": [
              "null",
              "string"
            ],
            "description": "An artist of the Manga"
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The ISO language-code of a translation"
          },
          "mangaUpdatesSeriesId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The MangaUpdates.com series id",
            "format": "int64"
          }
        },
        "description": "The query to use when searching for a Manga"
      }
    }
  },
  "tags": [
    {
      "name": "Search"
    },
    {
      "name": "Download"
    }
  ]
}