{
  "openapi": "3.1.1",
  "info": {
    "title": "API | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/mangas": {
      "get": {
        "tags": [
          "Info"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaMetadata"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/mangas/{mangaId}": {
      "get": {
        "tags": [
          "Info"
        ],
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MangaMetadata"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/mangas/{mangaId}/cover": {
      "get": {
        "tags": [
          "Info"
        ],
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/mangas/search": {
      "post": {
        "tags": [
          "Search"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchQuery"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MangaMetadata"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/mangas/{mangaId}/match": {
      "post": {
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MatchResult"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContentRating": {
        "enum": [
          "Safe",
          "Suggestive",
          "Erotica",
          "Pornographic",
          null
        ]
      },
      "MangaMetadata": {
        "required": [
          "metadataExtensionId",
          "identifier",
          "url",
          "mangaId",
          "series",
          "summary",
          "coverId"
        ],
        "type": "object",
        "properties": {
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "chaptersNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MatchResult": {
        "required": [
          "downloadExtensionId",
          "identifier",
          "url",
          "mangaId",
          "series",
          "summary",
          "coverId"
        ],
        "type": "object",
        "properties": {
          "downloadExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "chaptersNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "null",
              "string"
            ],
            "description": "The title of the Manga."
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "contentRating": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ContentRating"
              }
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The release-year of the Manga",
            "format": "int32"
          },
          "author": {
            "type": [
              "null",
              "string"
            ],
            "description": "An author of the Manga"
          },
          "artist": {
            "type": [
              "null",
              "string"
            ],
            "description": "An artist of the Manga"
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The ISO language-code of a translation"
          },
          "mangaUpdatesSeriesId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The MangaUpdates.com series id",
            "format": "int64"
          }
        },
        "description": "The query to use when searching for a Manga"
      }
    }
  },
  "tags": [
    {
      "name": "Info"
    },
    {
      "name": "Search"
    }
  ]
}