  "components": {
    "schemas": {
      "ContentRating": {
        "enum": [
          "Safe",
          "Suggestive",
          "Erotica",
          "Pornographic",
          null
        ]
      },
      "DownloadExtensionsList": {
        "type": "object",
        "properties": {
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IDownloadExtension"
            }
          }
        }
      },
      "DownloadLink": {
        "required": [
          "mangaId",
          "downloadId",
          "downloadExtensionId",
          "identifier",
          "matched",
          "priority",
          "series",
          "summary",
          "url",
          "coverId"
        ],
        "type": "object",
        "properties": {
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "downloadId": {
            "type": "string",
            "format": "uuid"
          },
          "downloadExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "matched": {
            "type": "boolean"
          },
          "priority": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "IDownloadExtension": {
        "type": "object",
        "properties": {
          "downloadExtensionsId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "iconUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "IMetadataExtension": {
        "type": "object",
        "properties": {
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "iconUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "Manga": {
        "required": [
          "mangaId",
          "monitored"
        ],
        "type": "object",
        "properties": {
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "monitored": {
            "type": "boolean"
          },
          "metadataEntry": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Metadata"
              }
            ]
          }
        }
      },
      "Metadata": {
        "required": [
          "metadataId",
          "metadataExtensionId",
          "identifier",
          "series",
          "summary",
          "coverId",
          "url"
        ],
        "type": "object",
        "properties": {
          "metadataId": {
            "type": "string",
            "format": "uuid"
          },
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "chosen": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "chaptersNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ReleaseStatus"
              }
            ]
          }
        }
      },
      "MetadataExtensionsList": {
        "type": "object",
        "properties": {
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IMetadataExtension"
            }
          }
        }
      },
