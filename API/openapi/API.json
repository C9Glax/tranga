        "required": [
          "mangaIds",
          "metadataId",
          "metadataExtensionId",
          "identifier",
          "series",
          "summary",
          "coverId",
          "url"
        ],
        "type": "object",
        "properties": {
          "mangaIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "metadataId": {
            "type": "string",
            "format": "uuid"
          },
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "chosen": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "chaptersNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ReleaseStatus"
              }
            ]
          }
        }
      },
      "PatchMangaDownloadSourceMatchedRequest": {
        "required": [
          "matched",
          "priority"
        ],
        "type": "object",
        "properties": {
          "matched": {
            "type": "boolean"
          },
          "priority": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PatchMangaMetadataEntryRequest": {
        "required": [
          "metadataId"
        ],
        "type": "object",
        "properties": {
          "metadataId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "PostSearchMangaRequest": {
        "required": [
          "searchQuery",
          "metadataExtensionIds"
        ],
        "type": "object",
        "properties": {
          "searchQuery": {
            "$ref": "#/components/schemas/SearchQuery"
          },
          "metadataExtensionIds": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "ReleaseStatus": {
        "enum": [
          "Ongoing",
          "Complete",
          "Hiatus",
          "Cancelled",
          null
        ]
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "null",
              "string"
            ],
            "description": "The title of the Manga."
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "contentRating": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ContentRating"
              }
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The release-year of the Manga",
            "format": "int32"
          },
          "author": {
            "type": [
              "null",
              "string"
            ],
            "description": "An author of the Manga"
          },
          "artist": {
            "type": [
              "null",
              "string"
            ],
            "description": "An artist of the Manga"
          },
          "language": {
            "type": [
              "null",
              "string"
            ],
            "description": "The ISO language-code of a translation"
          },
          "mangaUpdatesSeriesId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "description": "The MangaUpdates.com series id",
            "format": "int64"
          },
          "mangaDexSeriesId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        },
        "description": "The query to use when searching for a Manga"
      }
    }
