{
  "openapi": "3.1.1",
  "info": {
    "title": "Services.Notifications | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/notifications/extensions": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "summary": "Get configured notification extensions.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NotificationExtension"
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Notifications"
        ],
        "summary": "Add a notification extension.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PutExtensionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationExtension"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/notifications/extensions/naprise": {
      "put": {
