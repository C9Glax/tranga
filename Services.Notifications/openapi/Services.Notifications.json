  "components": {
    "schemas": {
      "NotificationExtension": {
        "required": [
          "id",
          "name",
          "type"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/NotificationExtensionType"
          }
        }
      },
      "NotificationExtensionType": {
        "enum": [
          "Naprise",
          "Discord",
          "Gotify",
          "NtfySh",
          "Telegram"
        ]
      },
      "PutExtensionRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "PutExtensionRequestDiscord": {
        "required": [
          "webhookId",
          "webhookToken",
          "name"
        ],
        "type": "object",
        "properties": {
          "webhookId": {
            "type": "string"
          },
          "webhookToken": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PutExtensionRequestGotify": {
        "required": [
          "host",
          "port",
          "appToken",
          "name"
        ],
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          },
          "port": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "appToken": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PutExtensionRequestNapriseServiceUrl": {
        "required": [
          "serviceUrl",
          "name"
        ],
        "type": "object",
        "properties": {
          "serviceUrl": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PutExtensionRequestNtfySh": {
        "required": [
          "host",
          "port",
          "topic",
          "name"
        ],
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          },
          "port": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "topic": {
            "type": "string"
          },
          "user": {
            "type": [
              "null",
              "string"
            ]
          },
          "password": {
            "type": [
              "null",
              "string"
            ]
          },
          "name": {
            "type": "string"
          }
        }
      },
      "PutExtensionRequestTelegram": {
        "required": [
          "token",
          "chatId",
          "name"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Notifications"
    }
  ]
}