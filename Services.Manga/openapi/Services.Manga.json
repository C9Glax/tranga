  "components": {
    "schemas": {
      "ContentRating": {
        "enum": [
          "Safe",
          "Suggestive",
          "Erotica",
          "Pornographic",
          null
        ]
      },
      "DownloadExtensionsList": {
        "type": "object",
        "properties": {
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IDownloadExtension"
            }
          }
        }
      },
      "DownloadLink": {
        "required": [
          "downloadId",
          "downloadExtensionId",
          "identifier",
          "series",
          "summary",
          "url",
          "coverId",
          "nsfw"
        ],
        "type": "object",
        "properties": {
          "downloadId": {
            "type": "string",
            "format": "uuid"
          },
          "downloadExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "nsfw": {
            "type": [
              "null",
              "boolean"
            ]
          }
        }
      },
      "IDownloadExtension": {
        "type": "object",
        "properties": {
          "downloadExtensionsId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "iconUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "IMetadataExtension": {
        "type": "object",
        "properties": {
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "iconUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "Manga": {
        "required": [
          "mangaId",
          "monitored"
        ],
        "type": "object",
        "properties": {
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "monitored": {
            "type": "boolean"
          },
          "metadataEntry": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Metadata"
              }
            ]
          },
          "downloadLinks": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/DownloadLink"
            }
          }
        }
      },
      "MangaDownloadLink": {
        "required": [
          "mangaId",
          "matched",
          "priority",
          "downloadId",
          "downloadExtensionId",
          "identifier",
          "series",
          "summary",
          "url",
          "coverId",
          "nsfw"
        ],
        "type": "object",
        "properties": {
          "mangaId": {
            "type": "string",
            "format": "uuid"
          },
          "matched": {
            "type": "boolean"
          },
          "priority": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "downloadId": {
            "type": "string",
            "format": "uuid"
          },
          "downloadExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "nsfw": {
            "type": [
              "null",
              "boolean"
            ]
          }
        }
      },
      "Metadata": {
        "required": [
          "metadataId",
          "metadataExtensionId",
          "identifier",
          "series",
          "summary",
          "coverId",
          "url",
          "nsfw"
        ],
        "type": "object",
        "properties": {
          "metadataId": {
            "type": "string",
            "format": "uuid"
          },
          "metadataExtensionId": {
            "type": "string",
            "format": "uuid"
          },
          "identifier": {
            "type": "string"
          },
          "chosen": {
            "type": [
              "null",
              "boolean"
            ]
          },
          "series": {
            "maxLength": 1024,
            "minLength": 0,
            "type": "string"
          },
          "summary": {
            "maxLength": 4096,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "language": {
            "maxLength": 8,
            "minLength": 0,
            "type": [
              "null",
              "string"
            ]
          },
          "chaptersNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "coverId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ReleaseStatus"
              }
            ]
          },
          "nsfw": {
            "type": [
              "null",
              "boolean"
            ]
          }
        }
      },
      "MetadataExtensionsList": {
        "type": "object",
        "properties": {
          "extensions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IMetadataExtension"
            }
          }
        }
      },
      "PatchMangaDownloadLinkRequest": {
        "required": [
          "matched",
          "priority"
        ],
        "type": "object",
        "properties": {
          "matched": {
            "type": "boolean"
          },
          "priority": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PostSearchMangaRequest": {
        "required": [
          "searchQuery",
          "metadataExtensionIds"
        ],
        "type": "object",
        "properties": {
          "searchQuery": {
            "$ref": "#/components/schemas/SearchQuery"
          },
          "metadataExtensionIds": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "ReleaseStatus": {
        "enum": [
          "Ongoing",
          "Complete",
          "Hiatus",
          "Cancelled",
          null
        ]
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "tags": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "contentRating": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ContentRating"
              }
            ]
          },
          "year": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "author": {
            "type": [
              "null",
              "string"
            ]
          },
          "artist": {
            "type": [
              "null",
              "string"
            ]
          },
          "language": {
            "type": [
              "null",
              "string"
            ]
          },
          "mangaUpdatesSeriesId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "mangaDexSeriesId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      }
    }
  },
