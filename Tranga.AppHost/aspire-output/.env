# Container image name for frontend
FRONTEND_IMAGE=

# Parameter PostgresPassword
POSTGRESPASSWORD="postgres"

# Parameter PostgresUser
POSTGRESUSER="postgres"

# Parameter RabbitMqPassword
RABBITMQPASSWORD="tranga"

# Parameter RabbitMqUser
RABBITMQUSER="tranga"

# Container image name for services-manga
SERVICES_MANGA_IMAGE=

# Default container port for services-manga
SERVICES_MANGA_PORT=3001

# Container image name for services-tasks
SERVICES_TASKS_IMAGE=

# Default container port for services-tasks
SERVICES_TASKS_PORT=3002

