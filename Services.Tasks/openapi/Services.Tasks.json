{
  "openapi": "3.1.1",
  "info": {
    "title": "Services.Tasks | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/tasks": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "Get all Tasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{taskId}": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "Get Task",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/tasks/create/getMangaChapters/{mangaId}": {
      "put": {
        "tags": [
          "Tasks"
        ],
        "summary": "Create a Task to get the Chapters of the Manga with requested ID.",
        "parameters": [
          {
            "name": "mangaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunOnceTask"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RunOnceTask": {
        "required": [
          "hasRun",
          "taskId",
          "taskTypeId",
          "taskTypeName",
          "taskType"
        ],
        "type": "object",
        "properties": {
          "hasRun": {
            "type": "boolean"
          },
          "taskId": {
            "type": "string",
            "format": "uuid"
          },
          "taskTypeId": {
            "type": "string",
            "format": "uuid"
          },
          "taskTypeName": {
            "type": "string"
          },
          "taskType": {
            "$ref": "#/components/schemas/TaskType"
          }
        }
      },
      "Task": {
        "required": [
          "taskId",
          "taskTypeId",
          "taskTypeName",
          "taskType"
        ],
        "type": "object",
        "properties": {
          "taskId": {
            "type": "string",
            "format": "uuid"
          },
          "taskTypeId": {
            "type": "string",
            "format": "uuid"
          },
          "taskTypeName": {
            "type": "string"
          },
          "taskType": {
            "$ref": "#/components/schemas/TaskType"
          }
        }
      },
      "TaskType": {
        "enum": [
          "PeriodicTask",
          "RunOnceTask"
        ]
      }
    }
  },
  "tags": [
    {
      "name": "Tasks"
    }
  ]
}